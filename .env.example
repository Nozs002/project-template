# Mẫu cấu hình biến môi trường
# Copy nội dung file này sang file .env và điền thông tin thật của bạn vào.

# Chuỗi kết nối MongoDB Atlas
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/my_database?retryWrites=true&w=majority"

